{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stored user preferences and personal data",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "email": { "type": "string" },
        "companyName": { "type": "string" },
        "logo": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "email"]
    },
    "Quote": {
      "title": "Price Quote",
      "description": "Complete data for a price quote",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "companyName": { "type": "string" },
        "clientName": { "type": "string" },
        "date": { "type": "string" },
        "quoteNumber": { "type": "string" },
        "items": {
          "type": "array",
          "items": { "$ref": "#/entities/QuoteItem" }
        },
        "logo": { "type": "string" },
        "paymentTerms": { "type": "string" },
        "exportSettings": { "$ref": "#/entities/ExportSettings" },
        "status": { "type": "string", "enum": ["Koncept", "Odoslaná", "Prijatá", "Odmietnutá"] },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "quoteNumber", "items", "status"]
    },
    "QuoteItem": {
      "title": "Quote Item",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "description": { "type": "string" },
        "unit": { "type": "string" },
        "quantity": { "type": "number" },
        "unitPrice": { "type": "number" }
      }
    },
    "ExportSettings": {
      "title": "Export Settings",
      "type": "object",
      "properties": {
        "columns": { "type": "array" },
        "primaryColor": { "type": "string" },
        "accentColor": { "type": "string" },
        "headerFontSize": { "type": "number" },
        "includeVAT": { "type": "boolean" },
        "vatRate": { "type": "number" }
      }
    },
    "CatalogItem": {
      "title": "Catalog Item",
      "description": "Reusable item for quotes",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "mj": { "type": "string" },
        "defaultPrice": { "type": "number" },
        "category": { "type": "string", "enum": ["Materiál", "Práca", "Doprava", "Iné"] },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "mj", "defaultPrice", "category"]
    },
    "Client": {
      "title": "Client",
      "description": "Stored client contact information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "company": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "ico": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name"]
    },
    "AllowedEmail": {
      "title": "Allowed Email",
      "description": "Email address allowed to register",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "addedBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "addedBy"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile document"
    },
    "/users/{userId}/quotes/{quoteId}": {
      "schema": "Quote",
      "description": "Collection of quotes for a specific user"
    },
    "/users/{userId}/catalog/{itemId}": {
      "schema": "CatalogItem",
      "description": "Personal library of items (materials/labor)"
    },
    "/users/{userId}/clients/{clientId}": {
      "schema": "Client",
      "description": "Personal address book of clients"
    },
    "/allowed_emails/{emailId}": {
      "schema": "AllowedEmail",
      "description": "Whitelist of allowed email addresses"
    }
  }
}
