rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 0.1 Primitives & Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'korsnakf@gmail.com';
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 1. Validation Blueprints (Anti-Update-Gap)
    
    function isValidQuote(data) {
      return data.id is string 
        && data.quoteNumber is string 
        && data.items is list 
        && data.items.size() <= 100
        && (data.status in ['Koncept', 'Odoslaná', 'Prijatá', 'Odmietnutá']);
    }

    function isValidCatalogItem(data) {
      return data.id is string
        && data.name is string && data.name.size() <= 200
        && data.mj is string && data.mj.size() <= 20
        && data.defaultPrice is number
        && (data.category in ['Materiál', 'Práca', 'Doprava', 'Iné']);
    }

    function isValidClient(data) {
      return data.id is string
        && data.name is string && data.name.size() <= 200;
    }

    // 2. Collection Rules

    // Allowed Emails (Admin only)
    match /allowed_emails/{emailId} {
      allow read, write: if isAdmin();
    }

    // User Data Root
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      
      // Quotes
      match /quotes/{quoteId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) 
          && isValidId(quoteId) 
          && isValidQuote(incoming());
        allow update: if isOwner(userId)
          && isValidQuote(incoming())
          && incoming().id == existing().id;
        allow delete: if isOwner(userId);
      }

      // Catalog
      match /catalog/{itemId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId)
          && isValidId(itemId)
          && isValidCatalogItem(incoming());
        allow update: if isOwner(userId)
          && isValidCatalogItem(incoming())
          && incoming().id == existing().id;
        allow delete: if isOwner(userId);
      }

      // Clients
      match /clients/{clientId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId)
          && isValidId(clientId)
          && isValidClient(incoming());
        allow update: if isOwner(userId)
          && isValidClient(incoming())
          && incoming().id == existing().id;
        allow delete: if isOwner(userId);
      }
    }
  }
}
